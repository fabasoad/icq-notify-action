{
  "name": "icq-notify-action",
  "version": "3.0.3",
  "description": "ICQ Notify GitHub Action",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:fabasoad/icq-notify-action.git"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "lint": "biome lint --write src",
    "test": "vitest run --coverage",
    "clean": "rm -rf coverage && rm -rf temp",
    "clean:unsafe": "rm -f pnpm-lock.yaml && rm -rf node_modules && rm -rf dist"
  },
  "keywords": [
    "actions",
    "github-actions"
  ],
  "author": "Yevhen Fabizhevskyi",
  "license": "MIT",
  "homepage": "https://github.com/fabasoad/icq-notify-action#readme",
  "dependencies": {
    "@actions/core": "~3.0.1",
    "@actions/tool-cache": "~4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.5.5",
    "@types/node": "~26.1.1",
    "@vitest/coverage-v8": "~4.1.10",
    "esbuild": "~0.28.1",
    "icq-bot": "~2.1.45",
    "typescript": "~7.0.2",
    "vitest": "~4.1.10"
  },
  "packageManager": "pnpm@11.13.1"
}
